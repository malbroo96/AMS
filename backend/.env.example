# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MSSQL (required) — all AMS data is stored in SQL Server
# Do NOT set USE_LOCAL_AUTH=true unless you need the old JSON file for debugging.
USE_LOCAL_AUTH=false
DB_SERVER=localhost
DB_INSTANCE=SQLEXPRESS
DB_PORT=1433
DB_NAME=AMS
DB_USER=sa
DB_PASSWORD=YourPassword123
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Uploads (local fallback)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Cloudinary (optional — set USE_CLOUDINARY=true to enable)
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=eadmin-portal

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
