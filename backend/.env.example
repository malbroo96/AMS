DB_TRUST_SERVER_CERTIFICATE=true

# Windows Authentication, matching SSMS "Windows Authentication".
DB_TRUSTED_CONNECTION=true
DB_ODBC_DRIVER=SQL Server

# SQL Authentication alternative:
# DB_TRUSTED_CONNECTION=false
# DB_USER=sa
# DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Uploads (local fallback)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Cloudinary (optional — set USE_CLOUDINARY=true to enable)
USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=eadmin-portal

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
